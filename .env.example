# Database
POSTGRES_USER=vyapar
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vyapardhara
DATABASE_URL=postgresql+asyncpg://vyapar:changeme@postgres:5432/vyapardhara

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Service ports
INGESTION_PORT=8001
MATCHING_PORT=8002
VYAPARCARD_PORT=8003
LIVELINK_PORT=8004
ACTIVITY_PORT=8005
DASHBOARD_PORT=3000

# Crypto (generate via: openssl ecparam -name prime256v1 -genkey -noout -out ec.pem)
ECDSA_PRIVATE_KEY_PATH=./secrets/ec_private.pem
ECDSA_PUBLIC_KEY_PATH=./secrets/ec_public.pem
JWT_SECRET=replace-me

# Pseudonymizer salt
PSEUDONYM_SALT=replace-me

# Polling intervals (seconds)
POLL_INTERVAL_LABOUR=300
POLL_INTERVAL_FACTORIES=300
POLL_INTERVAL_KSPCB=600
POLL_INTERVAL_SHOP_ESTAB=300
